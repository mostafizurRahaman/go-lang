{
   "workbench.colorTheme": "Andromeda Bordered",

   // 👁️ Eye-Friendly Editor Appearance
   "editor.fontFamily": "'Operator Mono Lig','Fira Code', Consolas, monospace",
   "editor.fontSize": 22,
   "editor.fontLigatures": true,
   "editor.lineHeight": 26,
   "editor.letterSpacing": 0.4,
   "editor.cursorBlinking": "solid",
   "editor.cursorSmoothCaretAnimation": "on",
   "editor.smoothScrolling": true,

   // Clean UI (less distraction)
   "workbench.statusBar.visible": false,
   "breadcrumbs.enabled": false,

   // Formatting
   "editor.formatOnSave": true,
   "editor.defaultFormatter": "esbenp.prettier-vscode",
   "prettier.tabWidth": 3,
   "prettier.proseWrap": "always",

   // Editor Behavior
   "editor.tabSize": 3,
   "editor.wordWrap": "on",
   "editor.linkedEditing": true,
   "editor.quickSuggestions": {
      "comments": "on",
      "strings": "on",
      "other": "on"
   },

   // 👇 SOFT BLOCK / INDENT HIGHLIGHTING (no harsh colors)
   "editor.guides.indentation": true,
   "editor.guides.highlightActiveIndentation": true,
   "editor.guides.bracketPairs": true,
   "editor.guides.highlightActiveBracketPair": true,
   "editor.bracketPairColorization.enabled": true,
   "editor.matchBrackets": "always",
   "editor.renderLineHighlight": "gutter",

   // Auto Save (not too aggressive)
   "files.autoSave": "afterDelay",
   "files.autoSaveDelay": 800,

   // Terminal
   "terminal.integrated.defaultProfile.windows": "Git Bash",
   "terminal.integrated.fontFamily": "'Fira Code'",
   "terminal.integrated.fontSize": 15,
   "terminal.integrated.lineHeight": 1.3,

   // Emmet
   "emmet.triggerExpansionOnTab": true,
   "emmet.showAbbreviationSuggestions": false,
   "emmet.useInlineCompletions": true,
   "emmet.includeLanguages": {
      "javascript": "javascriptreact"
   },

   // Extensions Support
   "tailwindCSS.emmetCompletions": true,
   "javascript.updateImportsOnFileMove.enabled": "always",

   // Auto Tag
   "auto-rename-tag.activationOnLanguage": ["*"],
   "auto-close-tag.activationOnLanguage": [
      "html",
      "xml",
      "javascript",
      "javascriptreact",
      "typescript",
      "typescriptreact",
      "vue"
   ],

   // Live Server
   "liveServer.settings.wait": 100,
   "liveServer.settings.CustomBrowser": "chrome",
   "liveServer.settings.donotShowInfoMsg": true,
   "liveServer.settings.donotVerifyTags": true,

   // Sass
   "liveSassCompile.settings.formats": [
      {
         "format": "compressed",
         "extensionName": ".min.css",
         "savePath": "/css"
      }
   ],
   "liveSassCompile.settings.generateMap": false,

   // 🎨 SOFT ANDROMEDA COLORS (Best for Eyes)
   "workbench.colorCustomizations": {
      "editor.background": "#1e1e2e",
      "editor.foreground": "#d4d4d4",

      "sideBar.background": "#181825",
      "activityBar.background": "#181825",
      "titleBar.activeBackground": "#181825",
      "statusBar.background": "#181825",

      "tab.activeBackground": "#313244",
      "tab.activeForeground": "#ffffff",
      "tab.inactiveBackground": "#1e1e2e",
      "tab.inactiveForeground": "#888888",

      "editor.lineHighlightBackground": "#2a2a3c",
      "editorCursor.foreground": "#cdd6f4",

      "editorIndentGuide.background": "#3b3b4f",
      "editorIndentGuide.activeBackground": "#6c7086",

      "scrollbarSlider.background": "#585b70",
      "scrollbarSlider.hoverBackground": "#6c7086",

      "editor.selectionBackground": "#45475a55",
      "editor.inactiveSelectionBackground": "#31324433"
   },

   // 🌈 SOFT SYNTAX COLORS (no neon)
   "editor.tokenColorCustomizations": {
      "comments": "#6c7086",
      "keywords": "#cba6f7",
      "strings": "#a6e3a1",
      "functions": "#89b4fa",
      "variables": "#f5c2e7",
      "numbers": "#f9e2af",
      "types": "#94e2d5"
   },

   // 🔥 BLOCKMAN (soft layered depth)
   "blockman.n01LineColor": "#6c7086",
   "blockman.n02LineColor": "#585b70",
   "blockman.n03LineColor": "#45475a",
   "blockman.n04LineColor": "#313244",
   "blockman.highlightActiveBlock": true,
   "blockman.focusBlock": true,
   "workbench.iconTheme": "material-icon-theme",
   "workbench.sideBar.location": "right",
   "js/ts.updateImportsOnFileMove.enabled": "always",
   "github.copilot.inlineSuggest.enable": false,
   "github.copilot.enable": {
      "*": false,
      "plaintext": false,
      "markdown": false,
      "scminput": false
   },
   "markdown-preview-enhanced.previewTheme": "atom-dark.css",
   "[go]": {
      "editor.defaultFormatter": "golang.go"
   },
   "gitlens.ai.model": "vscode",
   "gitlens.ai.vscode.model": "copilot:gpt-4.1"
}
